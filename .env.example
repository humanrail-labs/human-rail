# ==========================================
# HumanRail Frontend - Environment Variables
# Copy to .env.local for local development
# Set in Vercel Dashboard for production
# ==========================================

# Solana Cluster Configuration
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# Options: mainnet-beta, devnet, localnet

# Custom RPC Endpoints (optional - defaults to public endpoints)
# NEXT_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com
# NEXT_PUBLIC_RPC_FALLBACK_ENDPOINT=https://api.devnet.solana.com

# ==========================================
# Program IDs (Devnet - from Anchor.toml)
# ==========================================
NEXT_PUBLIC_HUMAN_REGISTRY_PROGRAM_ID=GB35h1zNh8WK5c72yVXu6gk6U7eUMFiTTymrXk2dfHHo
NEXT_PUBLIC_AGENT_REGISTRY_PROGRAM_ID=GLrs6qS2LLwKXZZuZXLFCaVyxkjBovbS2hM9PA4ezdhQ
NEXT_PUBLIC_DELEGATION_PROGRAM_ID=DiNpgESa1iYxKkqmpCu8ULaXEmhqvD33ADGaaH3qP7XT
NEXT_PUBLIC_RECEIPTS_PROGRAM_ID=EFjLqSdPv45PmdhUwaFGRwCfENo58fRCtwTvqnQd8ZwM
NEXT_PUBLIC_HUMAN_PAY_PROGRAM_ID=HpMrfeC5gJZdywnUQS4WEvsUs6edyjrEmLuYEF1W3qF9
NEXT_PUBLIC_DATA_BLINK_PROGRAM_ID=GYUeSsQfLYrYc5H27XdrssX5WgU4rNfkLGBnsksQcFpX
