# ==========================================
# KYC Service Configuration
# ==========================================
NEXT_PUBLIC_KYC_SERVICE_URL=https://humanrail-kyc-issuer.fly.dev
# Local development: http://localhost:3100

# ==========================================
# IMPORTANT NOTES
# ==========================================
# 1. NEVER commit .env.local to git
# 2. Veriff credentials go in the BACKEND only (KYC issuer service)
# 3. Frontend only needs the KYC service URL
# 4. All NEXT_PUBLIC_ variables are exposed to browser
