{
  "name": "humanrail-demo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:dwallet-guard": "bash scripts/check-dwallet-guard.sh",
    "deploy:dwallet-guard": "bash scripts/deploy-dwallet-guard.sh",
    "verify:dwallet-guard": "bash scripts/verify-dwallet-guard-deploy.sh",
    "devnet:create-guarded-dwallet": "tsx scripts/devnet-create-guarded-dwallet.ts",
    "devnet:inspect-ika": "tsx scripts/devnet-inspect-ika.ts",
    "devnet:inspect-ika:debug": "IKA_DEBUG_RAW=1 npm run devnet:inspect-ika",
    "ika:create-dwallet": "bash scripts/ika-create-dwallet.sh",
    "ika:dkg-check": "PROTOC=/home/codespace/.local/protoc/bin/protoc cargo check --manifest-path tools/ika-dkg-cli/Cargo.toml",
    "ika:transfer-authority": "tsx scripts/ika-transfer-authority.ts",
    "ika:create-guarded-policy": "tsx scripts/devnet-create-guarded-dwallet.ts --real-ika",
    "ika:verify-lifecycle": "tsx scripts/ika-verify-lifecycle.ts",
    "ika:approve-message": "tsx scripts/ika-approve-guarded-message.ts",
    "ika:sign-approved-message": "cargo run --manifest-path tools/ika-dkg-cli/Cargo.toml -- sign-approved-message --dwallet-artifact .local-ika/dwallet.json --request-artifact .local-ika/signing-request.json",
    "ika:verify-message-approval": "cargo run --manifest-path tools/ika-dkg-cli/Cargo.toml -- sign-approved-message --dwallet-artifact .local-ika/dwallet.json --request-artifact .local-ika/signing-request.json",
    "test:agent-cross-chain-tool": "tsx scripts/test-agent-cross-chain-tool.ts",
    "final:check": "bash scripts/final-submission-check.sh",
    "product:docker:up": "docker compose up -d postgres redis",
    "product:docker:down": "docker compose down",
    "product:db:generate": "cd packages/db && npx prisma generate",
    "product:db:push": "bash -c 'set -a && source .env.product && set +a && cd packages/db && npx prisma db push'",
    "product:db:migrate": "bash -c 'set -a && source .env.product && set +a && cd packages/db && npx prisma migrate dev'",
    "product:db:studio": "bash -c 'set -a && source .env.product && set +a && cd packages/db && npx prisma studio'",
    "product:api:dev": "npm --prefix apps/api run dev",
    "product:api:build": "npm --prefix apps/api run build",
    "product:api:start": "npm --prefix apps/api run start",
    "product:api:smoke": "node scripts/product-api-smoke.mjs",
    "product:import-devnet-artifacts": "tsx scripts/product-import-devnet-artifacts.ts",
    "product:health": "curl -s http://localhost:4000/health | jq . || curl -s http://localhost:4000/health"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@humanrail/agent": "file:packages/agent",
    "@humanrail/sdk": "file:packages/sdk",
    "@noble/hashes": "^2.2.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.28",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-solflare": "^0.6.32",
    "@solana/web3.js": "^1.98.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.26.2",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.170.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
