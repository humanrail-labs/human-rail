# ==========================================
# Mandara Product Backend - Environment
# Copy to .env.product for local development
# Do NOT commit .env.product to version control
# ==========================================

# Database
DATABASE_URL="postgresql://mandara:mandara@localhost:5432/mandara_dev?schema=public"

# Redis (prepared for BullMQ in future phases)
REDIS_URL="redis://:changeme@localhost:6379"

# API Server
MANDARA_API_PORT=4000
MANDARA_API_HOST="0.0.0.0"
MANDARA_ENV="development"
MANDARA_CORS_ORIGIN="http://localhost:3000"

# Secrets
# Required outside development. Used to encrypt webhook signing secrets at rest.
MANDARA_ENCRYPTION_PASSWORD="change-me-dev-only-32-byte-minimum"
# Used when hashing Mandara agent API keys.
MANDARA_API_KEY_PEPPER="change-me-dev-only-api-key-pepper"

# Solana / Ika
# Backend RPC URL (used by API worker and /api/rpc proxy)
MANDARA_SOLANA_RPC_URL="https://api.devnet.solana.com"
# For Vercel (server-side only): SOLANA_RPC_URL should match the above
# so the Next.js /api/rpc route can proxy private RPC credentials safely.
MANDARA_IKA_GRPC_URL="https://pre-alpha-dev-1.ika.ika-network.net:443"
MANDARA_HUMANRAIL_GUARD_PROGRAM_ID="Bzxgvxp9rZt2qeY7UNnvic9jHQdVFMw7mWzXvjuwLnT2"
MANDARA_IKA_DWALLET_PROGRAM_ID="87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY"

# Agent Chat LLM
# Defaults to deterministic parsing unless enabled. Keep provider keys server-side only.
MANDARA_LLM_ENABLED="false"
MANDARA_LLM_PROVIDER="deepseek"
MANDARA_LLM_API_KEY=""
MANDARA_LLM_MODEL="deepseek-chat"
MANDARA_LLM_BASE_URL="https://api.deepseek.com"
MANDARA_LLM_TIMEOUT_MS="20000"
MANDARA_LLM_MAX_INPUT_CHARS="4000"
MANDARA_LLM_MAX_OUTPUT_TOKENS="700"

# Optional fallback providers for future phases
MANDARA_LLM_GEMINI_API_KEY=""
MANDARA_LLM_GEMINI_MODEL="gemini-2.5-flash-lite"
MANDARA_LLM_GROQ_API_KEY=""
MANDARA_LLM_GROQ_MODEL="llama-3.1-8b-instant"

# Worker Mode
# - "dry-run" (default): simulates all on-chain steps without spending SOL or invoking Ika
# - "live-devnet": performs real Solana devnet transactions and Ika gRPC signing
MANDARA_WORKER_MODE="dry-run"

# Live Execution Safety Gate
# Set to "true" to enable live on-chain signing. This is an ADDITIONAL safety gate
# beyond MANDARA_WORKER_MODE. Both must be correctly set for live execution.
# NEVER enable live execution on mainnet. Devnet only.
MANDARA_ENABLE_LIVE_EXECUTION="false"

# Optional: path to service wallet keypair for on-chain transactions
# Required for live-devnet mode. Leave empty for dry-run.
# This keypair must be a devnet-only keypair with a small amount of SOL for rent/fees.
MANDARA_SERVICE_WALLET_PATH=""

# Optional: HTTP health server port for the worker
# If set, the worker exposes /health and /ready endpoints on this port.
# MANDARA_WORKER_HEALTH_PORT=4001

# Optional: path to pre-built ika-dkg-cli binary
# Used by the live-devnet worker image (Dockerfile.worker.devnet) instead of cargo run.
# MANDARA_IKA_CLI_PATH=/usr/local/bin/ika-dkg-cli
