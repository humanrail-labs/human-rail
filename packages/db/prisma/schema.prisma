generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──

enum AgentStatus {
  active
  suspended
  revoked
}

enum PolicyStatus {
  active
  frozen
  expired
  revoked
}

enum SigningRequestStatus {
  requested
  queued
  worker_processing
  policy_rejected
  guard_approved
  ika_pending
  signed
  failed
}

enum MessageApprovalStatus {
  pending
  signed
}

enum AuditEventType {
  organization_created
  organization_updated
  agent_created
  agent_updated
  agent_frozen
  agent_revoked
  policy_created
  policy_updated
  policy_frozen
  policy_expired
  signing_requested
  signing_approved
  signing_rejected
  signing_signed
  signing_failed
  api_key_created
  api_key_revoked
  webhook_created
  webhook_updated
  webhook_deleted
  webhook_delivered
  webhook_failed
  webhook_delivery_scheduled
  webhook_delivery_succeeded
  webhook_delivery_failed
  audit_export_created
  devnet_artifact_imported
  ika_dwallet_imported
  guarded_policy_imported
  signing_request_imported
  message_approval_imported
  guarded_policy_created
  signing_request_previewed
  signing_request_created
  signing_request_policy_rejected
  signing_request_queued
  signing_request_processing
  signing_request_dry_run_completed
  signing_request_execution_failed
  signing_request_worker_skipped
  signing_request_status_updated
  guard_message_approved
  ika_message_approval_created
  ika_signature_committed
  agent_api_key_used
  agent_chat_session_created
  agent_chat_message_created
  agent_chat_scope_rejected
  agent_chat_proposal_created
  agent_chat_proposal_previewed
  agent_chat_proposal_approved
  agent_chat_proposal_rejected
  agent_chat_request_created
  agent_chat_request_enqueued
  subscription_created
  subscription_limit_exceeded
  usage_recorded
  system
}

enum WebhookStatus {
  active
  paused
}

enum WebhookDeliveryStatus {
  pending
  retrying
  delivered
  failed
}

enum ChatMessageRole {
  user
  assistant
  system
  tool
}

enum AgentActionProposalStatus {
  draft
  preview_allowed
  preview_rejected
  user_approved
  user_rejected
  request_created
  queued
  failed
}

enum MandaraPlanCode {
  dev_free
  builder
  team
  enterprise
}

enum SubscriptionStatus {
  trial
  active
  past_due
  canceled
  expired
}

// ── Models ──

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  tier      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       Membership[]
  agents            Agent[]
  ikaDwallets       IkaDwallet[]
  guardedPolicies   GuardedPolicy[]
  signingRequests   SigningRequest[]
  auditEvents       AuditEvent[]
  webhooks          Webhook[]
  integrationSecrets IntegrationSecret[]
  agentChatSessions AgentChatSession[]
  agentActionProposals AgentActionProposal[]
  mandaraSubscription MandaraSubscription?
  mandaraUsageEvents MandaraUsageEvent[]

  @@index([slug])
  @@index([tier])
  @@map("organizations")
}

model User {
  id          String   @id @default(cuid())
  externalId  String   @unique
  email       String   @unique
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships Membership[]

  @@index([externalId])
  @@index([email])
  @@map("users")
}

model Membership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("member")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

model Agent {
  id                    String     @id @default(cuid())
  organizationId        String
  name                  String
  description           String?
  status                AgentStatus @default(active)
  onChainAgentPda       String?
  onChainProfilePda     String?
  onChainCapabilityPda  String?
  frozenAt              DateTime?
  revokedAt             DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiKeys         AgentApiKey[]
  signingRequests SigningRequest[]
  guardedPolicies GuardedPolicy[]
  agentChatSessions AgentChatSession[]
  agentActionProposals AgentActionProposal[]

  @@index([organizationId, status])
  @@index([onChainAgentPda])
  @@map("agents")
}

model AgentApiKey {
  id         String    @id @default(cuid())
  agentId    String
  name       String
  prefix     String    @unique
  hash       String
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@map("agent_api_keys")
}

model IkaDwallet {
  id                     String   @id @default(cuid())
  organizationId         String
  name                   String?
  onChainPda             String   @unique
  curve                  String
  publicKey              String?
  state                  String   @default("dkg_in_progress")
  authority              String?
  authorityTransferredAt DateTime?
  createdVia             String   @default("grpc_dkg")
  metadata               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  guardedPolicies GuardedPolicy[]
  signingRequests SigningRequest[]

  @@index([organizationId, state])
  @@index([onChainPda])
  @@map("ika_dwallets")
}

model GuardedPolicy {
  id                   String       @id @default(cuid())
  organizationId       String
  agentId              String
  ikaDwalletId         String
  name                 String?
  onChainPda           String?      @unique
  allowedChainId       Int
  allowedAsset         String?
  allowedRecipient     String?
  allowedAssetHash     String
  allowedRecipientHash String
  perTxLimit           Decimal      @db.Decimal(78, 0)
  dailyLimit           Decimal      @db.Decimal(78, 0)
  totalLimit           Decimal      @db.Decimal(78, 0)
  dailySpent           Decimal      @default(0) @db.Decimal(78, 0)
  totalSpent           Decimal      @default(0) @db.Decimal(78, 0)
  lastSpendDay         Int?
  expiresAt            DateTime?
  status               PolicyStatus @default(active)
  frozenAt             DateTime?
  metadata             Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent           Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  ikaDwallet      IkaDwallet       @relation(fields: [ikaDwalletId], references: [id], onDelete: Restrict)
  signingRequests SigningRequest[]
  agentActionProposals AgentActionProposal[]

  @@index([agentId, status])
  @@index([organizationId])
  @@index([onChainPda])
  @@map("guarded_policies")
}

model SigningRequest {
  id                        String                 @id @default(cuid())
  organizationId            String
  agentId                   String
  policyId                  String
  ikaDwalletId              String?
  requestId                 String                 @unique
  messageDigest             String
  messageMetadataDigest     String
  destinationChainId        Int
  asset                     String?
  recipient                 String?
  assetHash                 String
  recipientHash             String
  amount                    Decimal                @db.Decimal(78, 0)
  message                   String?
  signatureScheme           String
  status                    SigningRequestStatus   @default(requested)
  rejectionCode             Int?
  rejectionReason           String?
  onChainRequestPda         String?
  onChainMessageApprovalPda String?
  approveTxSignature        String?
  submittedAt               DateTime?
  signedAt                  DateTime?
  signatureHex              String?
  signatureBase64           String?
  executionJobId            String?
  metadata                  Json?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent            Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  policy           GuardedPolicy     @relation(fields: [policyId], references: [id], onDelete: Cascade)
  ikaDwallet       IkaDwallet?       @relation(fields: [ikaDwalletId], references: [id], onDelete: SetNull)
  messageApproval  MessageApproval?
  agentActionProposals AgentActionProposal[]

  @@index([executionJobId])
  @@index([organizationId, createdAt])
  @@index([agentId, status])
  @@index([requestId])
  @@index([onChainRequestPda])
  @@map("signing_requests")
}

model AgentChatSession {
  id              String             @id @default(cuid())
  organizationId  String
  agentId         String?
  title           String?
  status          String             @default("active")
  createdByUserId String?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        Agent?                @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages     AgentChatMessage[]
  proposals    AgentActionProposal[]

  @@index([organizationId])
  @@index([agentId])
  @@index([createdAt])
  @@map("agent_chat_sessions")
}

model AgentChatMessage {
  id        String          @id @default(cuid())
  sessionId String
  role      ChatMessageRole
  content   String
  provider  String?
  model     String?
  scopeAllowed Boolean?
  scopeReason  String?
  metadata  Json?
  createdAt DateTime        @default(now())

  session AgentChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("agent_chat_messages")
}

model AgentActionProposal {
  id                    String                    @id @default(cuid())
  sessionId             String
  organizationId         String
  agentId               String?
  policyId              String?
  signingRequestId      String?
  type                  String                    @default("signature_request")
  status                AgentActionProposalStatus  @default(draft)
  naturalLanguageIntent String
  structuredInput       Json
  policyDecision        Json?
  rejectionReason       String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  session        AgentChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent          Agent?           @relation(fields: [agentId], references: [id], onDelete: SetNull)
  policy         GuardedPolicy?   @relation(fields: [policyId], references: [id], onDelete: SetNull)
  signingRequest SigningRequest?  @relation(fields: [signingRequestId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([agentId])
  @@index([policyId])
  @@index([signingRequestId])
  @@map("agent_action_proposals")
}

model MandaraSubscription {
  id                  String             @id @default(cuid())
  organizationId      String             @unique
  planCode            MandaraPlanCode    @default(dev_free)
  status              SubscriptionStatus @default(trial)
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  monthlyChatLimit    Int                @default(100)
  monthlyRequestLimit Int                @default(50)
  monthlyWebhookLimit Int                @default(100)
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  usage        MandaraUsageEvent[]

  @@map("mandara_subscriptions")
}

model MandaraUsageEvent {
  id             String   @id @default(cuid())
  organizationId String
  subscriptionId String?
  type           String
  quantity       Int      @default(1)
  source         String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription MandaraSubscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([type])
  @@index([createdAt])
  @@map("mandara_usage_events")
}

model MessageApproval {
  id               String                @id @default(cuid())
  organizationId   String
  signingRequestId String                @unique
  onChainPda       String                @unique
  dwalletPda       String
  messageDigest    String
  metadataDigest   String
  approver         String
  userPubkey       String
  signatureScheme  String
  epoch            Decimal               @db.Decimal(78, 0)
  status           MessageApprovalStatus @default(pending)
  signatureLength  Int?
  signatureHex     String?
  signatureBase64  String?
  metadata         Json?
  fetchedAt        DateTime              @default(now())
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  signingRequest SigningRequest @relation(fields: [signingRequestId], references: [id], onDelete: Cascade)

  @@index([onChainPda])
  @@index([dwalletPda])
  @@index([organizationId])
  @@map("message_approvals")
}

model AuditEvent {
  id             String         @id @default(cuid())
  organizationId String
  actorType      String         // user, agent, system, worker
  actorId        String?
  eventType      AuditEventType
  resourceType   String?        // agent, policy, signing_request, wallet, api_key
  resourceId     String?
  summary        String?
  metadata       Json?
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([actorType, actorId])
  @@index([eventType])
  @@index([resourceType, resourceId])
  @@map("audit_events")
}

model Webhook {
  id             String            @id @default(cuid())
  organizationId String
  url            String
  secret         String            // AES-256-GCM encrypted ciphertext (hex); legacy rows may contain plaintext until backfilled
  iv             String?           // AES-256-GCM IV (hex); nullable for non-destructive legacy migration
  tag            String?           // AES-256-GCM auth tag (hex); nullable for non-destructive legacy migration
  events         String[]
  status         WebhookStatus     @default(active)
  metadata       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organizationId, status])
  @@map("webhooks")
}

model WebhookDelivery {
  id                String                @id @default(cuid())
  organizationId    String
  webhookId         String
  eventType         String
  payload           Json
  status            WebhookDeliveryStatus @default(pending)
  responseStatus    Int?
  responseBody      String?
  error             String?
  attemptedAt       DateTime              @default(now())
  retryCount        Int                   @default(0)
  nextRetryAt       DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, attemptedAt])
  @@index([nextRetryAt])
  @@index([organizationId, status])
  @@map("webhook_deliveries")
}

model IntegrationSecret {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  value          String   // AES-256-GCM encrypted
  iv             String   // base64
  tag            String   // base64
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@map("integration_secrets")
}
